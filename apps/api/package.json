{
  "name": "@joobi/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:seed": "tsx src/db/seed.ts",
    "audit:joobi": "tsx ../../scripts/audit-joobi.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\""
  },
  "dependencies": {
    "@joobi/shared": "workspace:*",
    "bullmq": "^5.7.0",
    "drizzle-orm": "^0.30.10",
    "express": "^4.19.2",
    "geoip-lite": "^1.4.10",
    "ioredis": "^5.4.1",
    "nanoid": "^5.0.7",
    "pg": "^8.11.5",
    "pino": "^9.0.0",
    "pino-http": "^10.1.0",
    "postgres": "^3.4.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/geoip-lite": "^1.4.4",
    "@types/node": "^20.12.7",
    "@types/pg": "^8.11.5",
    "drizzle-kit": "^0.20.17",
    "eslint": "^8.57.0",
    "tsx": "^4.7.2",
    "typescript": "^5.4.5",
    "vitest": "^1.5.0",
    "supertest": "^7.0.0",
    "@types/supertest": "^6.0.2"
  }
}
